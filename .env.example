# .env.example
# Copy this file to .env for local development with `netlify dev`, and set
# the same values under Site settings > Environment variables in Netlify
# for production deploys. NEVER commit a real .env file.

# --- Airtable (required) ---
# Personal Access Token from https://airtable.com/create/tokens with at
# least data.records:read + data.records:write scope on the ProductNova base.
AIRTABLE_TOKEN=

# The ProductNova base ID (already created/populated - see AIRTABLE_SCHEMA.md)
AIRTABLE_BASE_ID=app4hkkQMCZGBwGGk

# --- Netlify Identity Admin API (optional local-dev fallback) ---
# In production, Netlify automatically supplies an Identity admin token to
# functions via context.clientContext.identity.token - you do NOT need to
# set this in the Netlify UI. Only set it locally if `netlify dev` doesn't
# populate context.clientContext.identity for you (see README "User
# Management" section for the manual fallback via the Identity tab UI).
IDENTITY_ADMIN_TOKEN=
